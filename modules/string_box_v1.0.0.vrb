note String Box Utility v1.0.0 for Verba

define draw_box needing text:
    note Draws a beautiful box around the specified text.
    len = the result of running strings.length with text.
    border = the result of running strings.repeat with "=", len + 4.
    say border.
    say "| ", text, " |".
    say border.
end.

define header needing text:
    note Prints a center-aligned header style.
    say "::: ", text, " :::".
end.
